{
  "version": 2,
  "name": "ted-tech-express-desk",
  "framework": null,

  "builds": [
    {
      "src": "ted/frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist",
        "buildCommand": "npm install && npm run build"
      }
    },
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb",
        "runtime": "python3.11"
      }
    }
  ],

  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.py"
    },
    {
      "src": "/metrics",
      "dest": "api/index.py"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],

  "env": {
    "USE_LOCAL_MOCK": "true",
    "JWT_ALGORITHM": "HS256",
    "JWT_EXPIRY_MINUTES": "60"
  },

  "github": {
    "enabled": true,
    "autoAlias": true
  }
}
