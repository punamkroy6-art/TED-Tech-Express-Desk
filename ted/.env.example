# Database Configuration
DATABASE_URL=postgresql+asyncpg://ted_user:change_me_in_production@db:5432/ted
DB_PASSWORD=change_me_in_production

# Redis Configuration
REDIS_URL=redis://:change_me_in_production@redis:6379/0
REDIS_PASSWORD=change_me_in_production

# JWT Authentication
JWT_SECRET=generate_a_random_jwt_secret_hex_key_here
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=15

# LLM Providers Configuration
GROQ_API_KEY=gsk_placeholder_key
GROQ_MODEL=llama-3.3-70b-versatile
AZURE_OPENAI_KEY=
AZURE_OPENAI_ENDPOINT=

# Freshworks ITSM Configuration
FRESHWORKS_DOMAIN=yourcompany.freshservice.com
FRESHWORKS_API_KEY=your_freshworks_api_key

# RAG & Diagnostics Configuration
CONFIDENCE_THRESHOLD=0.80
RAG_TOP_K=3
SESSION_TIMEOUT_MINUTES=5
