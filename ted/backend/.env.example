# TED Backend — Environment Variables
# Copy this file to .env and fill in your values

# ── Mode ─────────────────────────────────────────────────────────────────
USE_LOCAL_MOCK=true          # true = SQLite + FakeRedis (no Postgres/Redis needed)

# ── Database ──────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./ted.db
REDIS_URL=redis://localhost:6379/0

# ── Auth ──────────────────────────────────────────────────────────────────
JWT_SECRET=generate-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60

# ── LLM (Groq or xAI) ────────────────────────────────────────────────────
# Groq free tier: https://console.groq.com  (key starts with gsk_)
# xAI / Grok:     https://console.x.ai      (key starts with xai-)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ── Freshservice ITSM ────────────────────────────────────────────────────
# Sign up free: https://freshservice.com/signup
# Get API key:  Profile Settings → API Key
FRESHWORKS_DOMAIN=yourcompany.freshservice.com
FRESHWORKS_API_KEY=your_raw_api_key_here

# ── App ───────────────────────────────────────────────────────────────────
CONFIDENCE_THRESHOLD=0.80
RAG_TOP_K=3
SESSION_TIMEOUT_MINUTES=5
